# Server Configuration
# Default: 0.0.0.0
HTTP_HOST=0.0.0.0
# Default: 5000
HTTP_PORT=5000

# Data Directory Configuration
# Default: /data
DATA_DIR=/data

# Database Configuration
# Options: sqlite, mysql
DATABASE_DRIVER=sqlite
# For sqlite: license.db
# For mysql: user:pass@tcp(host:port)/dbname?charset=utf8mb4
DATABASE_DSN=license.db

# Note: The actual database path will be: ${DATA_DIR}/${DATABASE_DSN}